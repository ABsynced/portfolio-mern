# MongoDB connection string. For a free hosted DB, create a cluster at https://www.mongodb.com/cloud/atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/portfolio?retryWrites=true&w=majority

# Port the API server runs on
PORT=5000

# URL of your deployed/local frontend, used for CORS
CLIENT_URL=http://localhost:5173
